<div class="page-header mb-4">
  <div class="row align-items-center">
    <div class="col">
      <div class="page-pretitle">
        <%= t :edit %>
      </div>
      <h2 class="page-title"><%= t :practice_settings %></h2>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="row row-cards">
    <div class="col-md-8">
      <%= render 'form-settings' %>
    </div>

    <div class="col-md-4">
      <div class="row">
        <div class="col-auto">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">
                <%= t('subscriptions.title') %> 
                
              </h3>
              <div class="card-actions">
                <%= label_tag t("subscriptions.status.#{@subscription.status}") %>
              </div>
            </div>

            <div class="card-body">
              <% if !@practice.has_linked_subscription? && @practice.has_active_subscription? %>
                <%= raw t('subscriptions.message_to_admin.trialing', stripe_url: link_to(t('subscriptions.cta.trialing'), subscriptions_url, method: :post).html_safe) %>
              <% elsif @practice.has_linked_subscription? && @practice.has_active_subscription? %>
                <%= raw t('subscriptions.message_to_admin.active', status: @subscription.status, stripe_url: link_to(t('subscriptions.cta.active'), subscriptions_url, method: :put).html_safe) %>
              <% else %>
                <%= raw t('subscriptions.message_to_admin.expired', stripe_url: link_to(t('subscriptions.cta.expired'), subscriptions_url, method: :post).html_safe) %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="row">
        <div class="col-auto">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">
                Payment Processing
              </h3>
              <div class="card-actions">
                <% if @practice.has_connect_account? %>
                  <%= content_tag :span, @practice.connect_onboarding_status.humanize, 
                                 class: "badge bg-#{status_badge_class(@practice.connect_onboarding_status)}-lt" %>
                <% else %>
                  <%= content_tag :span, "Not Configured", class: "badge bg-secondary-lt" %>
                <% end %>
              </div>
            </div>

            <div class="card-body">
              <% if @practice.connect_account_complete? %>
                <p class="text-success">✅ Your practice can accept payments directly from patients.</p>
                <p><%= link_to "Manage Payment Settings", connect_account_path, class: "btn btn-primary btn-sm" %></p>
              <% elsif @practice.has_connect_account? %>
                <p class="text-warning">⏳ Setup in progress. Complete your account setup to start accepting payments.</p>
                <p><%= link_to "Complete Setup", connect_account_path, class: "btn btn-warning btn-sm" %></p>
              <% else %>
                <p>Enable direct payment processing for your practice.</p>
                <p><%= link_to "Set Up Payments", connect_account_path, class: "btn btn-outline-primary btn-sm" %></p>
              <% end %>
            </div>
          </div>
        </div>
	    </div>
	  
      <div class="row">
        <div class="px-3">
	        <hr />
        </div>
      </div>

      <div class="row">
        <div class="px-3">
          <h3 class="card-title"><%= t :for_your_information %></h3>
          <%= raw t("instructions.practice", close_url: (link_to (t(:close_your_account)).downcase, practice_cancel_url)).html_safe %>
        </div>
      </div>
    </div>
  </div>
</div>