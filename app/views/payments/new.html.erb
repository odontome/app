<% content_for :title, "Create Payment Link" %>

<div class="page-header mb-4">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Create Payment Link</h2>
      <div class="text-muted mt-1">Generate a secure payment link for your patient</div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <%= form_with url: payments_path, local: true, class: "card" do |form| %>
        <div class="card-header">
          <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon me-2">
              <rect width="20" height="14" x="2" y="5" rx="2"/>
              <line x1="2" x2="22" y1="10" y2="10"/>
            </svg>
            Payment Information
          </h3>
        </div>
        
        <div class="card-body">
          <div class="mb-3">
            <%= form.label :patient_name, class: "form-label required" %>
            <%= form.text_field :patient_name, class: "form-control", placeholder: "Enter patient's full name", required: true %>
            <small class="form-hint">This will be displayed on the payment form and receipt</small>
          </div>
          
          <div class="row">
            <div class="col-md-4 mb-3">
              <%= form.label :currency, class: "form-label" %>
              <%= form.select :currency, options_for_select([
                    ['USD - US Dollar', 'usd'],
                    ['CAD - Canadian Dollar', 'cad'],
                    ['EUR - Euro', 'eur'],
                    ['MXN - Mexican Peso', 'mxn']
                  ], 'usd'), {}, { class: "form-select" } %>
            </div>

            <div class="col-md-8 mb-3">
              <%= form.label :amount, "Amount", class: "form-label required" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= form.number_field :amount, class: "form-control", step: 0.01, min: 1, value: 100.00, required: true %>
              </div>
              <small class="form-hint">Platform fee (1%) will be deducted automatically</small>
            </div>
          </div>
        </div>
        
        <div class="card-footer">
          <div class="row">
            <div class="col">
              <%= link_to "Cancel", payments_path, class: "btn btn-secondary" %>
            </div>
            <div class="col-auto">
              <%= form.submit "Create Payment Link", class: "btn btn-primary" %>
            </div>
          </div>
        </div>
      <% end %>
      
      <div class="card mt-3">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <span class="bg-blue text-white avatar me-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </span>
            <div>
              <div class="font-weight-medium">Secure Payment Link</div>
              <div class="text-muted">A unique, secure link will be generated using Stripe's built-in security. The link expires automatically in 24 hours.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>